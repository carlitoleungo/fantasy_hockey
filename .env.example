# Path to the SQLite session DB. Defaults to ./app.db (repo root) locally.
# Set to /data/app.db in production (Fly.io volume mount).
DB_PATH=./app.db

# Directory for parquet cache files. Defaults to ./.cache locally.
# Set to /data/cache in production (Fly.io volume mount).
CACHE_DIR=./.cache

# Set to "true" in production to enforce HTTPS-only cookies.
# Leave unset or "false" for local development (HTTP).
HTTPS_ONLY=false

# Yahoo OAuth credentials — required. Register at https://developer.yahoo.com/apps/
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# Must match the redirect URI registered in the Yahoo developer console.
# For local development, register http://localhost:8000/auth/callback.
YAHOO_REDIRECT_URI=http://localhost:8000/auth/callback
